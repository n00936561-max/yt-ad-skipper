{
  "manifest_version": 3,
  "name": "YouTube Ad Skipper",
  "version": "1.2",
  "description": "Auto-skips YouTube ads and shows real dislike counts",
  "permissions": ["storage"],
  "host_permissions": ["https://returnyoutubedislike.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js", "dislike.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Ad Skipper"
  }
}
